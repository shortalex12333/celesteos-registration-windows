# Master Supabase (auth + fleet registry)
MASTER_SUPABASE_URL=https://qvzmkaamzaqxpzbewjxe.supabase.co
MASTER_SUPABASE_SERVICE_KEY=your-service-role-key-here

# Microsoft Graph API for email
# App: CelesteOS.Outlook.Write (f0b8944b-8127-4f0f-8ed5-5487462df50c)
# Without these, service runs in debug mode (codes logged to console)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SENDER_EMAIL=contact@celeste7.ai

# Download portal URL (used in welcome email links)
PORTAL_BASE_URL=https://registration.celeste7.ai

# Admin guard for /api/send-welcome (optional — leave empty to disable)
ADMIN_API_KEY=

# Server
PORT=8001
